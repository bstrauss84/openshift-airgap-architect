{
  "name": "openshift-airgap-architect",
  "version": "1.7.0",
  "description": "OpenShift Airgap Installation Configuration Generator",
  "private": true,
  "scripts": {
    "sync-catalogs": "node scripts/sync-catalogs.js",
    "sync-catalogs:check": "node scripts/sync-catalogs.js --dry-run",
    "sync-catalogs:verbose": "node scripts/sync-catalogs.js --verbose",
    "validate-catalogs": "node scripts/validate-catalog.js frontend/src/data/catalogs/*.json",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/billstrauss/openshift-airgap-architect.git"
  },
  "author": "Bill Strauss",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
