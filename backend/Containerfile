# Stage: compute APP_GIT_SHA and APP_BUILD_TIME from .git when present (no git in final image)
FROM alpine AS build-info
RUN apk add --no-cache git
COPY . /ctx
WORKDIR /ctx
RUN SHA="unknown"; [ -d .git ] && SHA=$(git rev-parse HEAD 2>/dev/null) || true; \
    BT=$(date -u +"%Y-%m-%dT%H:%M:%SZ"); \
    echo "export APP_GIT_SHA=\"$SHA\"" > /tmp/build-env.sh && \
    echo "export APP_BUILD_TIME=\"$BT\"" >> /tmp/build-env.sh

FROM node:20-bookworm-slim

ARG OCP_CLIENT_URL="https://mirror.openshift.com/pub/openshift-v4/x86_64/clients/ocp/latest/openshift-client-linux.tar.gz"
ARG OCP_MIRROR_URL="https://mirror.openshift.com/pub/openshift-v4/x86_64/clients/ocp/latest/oc-mirror.tar.gz"

RUN apt-get update \
  && apt-get install -y --no-install-recommends curl ca-certificates tar python3 make g++ libgpgme11 openssh-client \
  && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL "${OCP_CLIENT_URL}" -o /tmp/oc.tgz \
  && tar -xzf /tmp/oc.tgz -C /usr/local/bin oc \
  && chmod +x /usr/local/bin/oc \
  && rm -f /tmp/oc.tgz

RUN curl -fsSL "${OCP_MIRROR_URL}" -o /tmp/oc-mirror.tgz \
  && tar -xzf /tmp/oc-mirror.tgz -C /usr/local/bin oc-mirror \
  && chmod +x /usr/local/bin/oc-mirror \
  && rm -f /tmp/oc-mirror.tgz

WORKDIR /app
COPY backend/package.json backend/package-lock.json* ./
RUN npm install --production
ARG CACHE_BUST=1
RUN echo "cache bust ${CACHE_BUST}" >/dev/null
COPY backend/src ./src
COPY backend/mock-data ./mock-data
COPY --from=build-info /tmp/build-env.sh /app/build-env.sh

ENV NODE_ENV=production
EXPOSE 4000
CMD ["/bin/sh", "-c", ". /app/build-env.sh 2>/dev/null || true; exec node src/index.js"]
